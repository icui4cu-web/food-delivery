{
	"extends": "astro/tsconfigs/base",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"paths": {
			"@layouts/*": ["./src/layouts/*"],
			"@components/*": ["./src/components/*"],
			"@scss/*": ["./src/scss/*"],
			"@js/*": ["./src/scripts/*"],
			"@data/*": ["./src/data/*"],
		}
	}
}
