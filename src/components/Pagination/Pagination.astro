---
import "./pagination.scss";

const { class: className } = Astro.props;
---

<ul class:list={[className, "pagination"]}>
	<li class="pagination__item pagination__item_optional">
		<a class="pagination__link" href="#" aria-label="Перша сторінка">««</a>
	</li>
	<li class="pagination__item pagination__item_optional" aria-hidden="true">…</li>
	<li class="pagination__item">
		<a class="pagination__link" href="#" aria-label="Попередня сторінка">«</a>
	</li>
	<li class="pagination__item">
		<a class="pagination__link" href="#">2</a>
	</li>
	<li class="pagination__item">
		<a class="pagination__link" href="#">3</a>
	</li>
	<li class="pagination__item">
		<span class="pagination__link">4</span>
	</li>
	<li class="pagination__item">
		<a class="pagination__link" href="#">5</a>
	</li>
	<li class="pagination__item">
		<a class="pagination__link" href="#">6</a>
	</li>
	<li class="pagination__item">
		<a class="pagination__link" href="#" aria-label="Наступна сторінка">»</a>
	</li>
	<li class="pagination__item pagination__item_optional" aria-hidden="true">…</li>
	<li class="pagination__item pagination__item_optional">
		<a class="pagination__link" href="#" aria-label="Остання сторінка">»»</a>
	</li>
</ul>
