---

import Filter from "@components/Filter/Filter.astro";
import ProductToolbar from "@components/ProductToolbar/ProductToolbar.astro";
import ProductsGrid from "@components/ProductsGrid/ProductsGrid.astro";
import ProductsList from "@components/ProductsList/ProductsList.astro";
import Pagination from "@components/Pagination/Pagination.astro";
import "./catalog.scss";

interface Props {
	view: "grid" | "list";
	class?: string;
	backgroundText: string;
}

const { class: className, view, backgroundText } = Astro.props;
---

<div class:list={[className, "catalog"]} data-background-text={backgroundText}>
	<Filter class="catalog__filter" />
	<div class="catalog__content">
		<ProductToolbar class="catalog__toolbar" />
		{view === 'grid' && <ProductsGrid />}
		{view === 'list' && <ProductsList />}
		<Pagination class="catalog__pagination" />
	</div>
</div>
