---
import type { HTMLTag, Polymorphic } from "astro/types";
import "./title.scss";

type Props<Tag extends HTMLTag> = Polymorphic<{
	as: Tag;
	size: 1 | 2 | 3 | 4 | 5 | 6;
	class?: string;
	line?: "start" | "end";
}>;

const { as: Tag, class: className, size, line } = Astro.props;
---

<Tag class:list={[className, `title title_size_${size}`, line && `title_line_${line}`]}
	><slot /></Tag
>
