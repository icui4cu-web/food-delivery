---
import Field from "@components/Field/Field.astro";
import Btn from "@components/Btn/Btn.astro";
import OTP from "@components/OTP/OTP.astro";
import "./phone-login.scss";
---

<div class="phone-login">
	<form id="phone-login-form" class="phone-login__step phone-login__step_active">
		<Field label="Номер телефону" component="input" id="phone" name="phone" data-phone-mask="" />
		<div class="phone-login__actions">
			<Btn class="phone-login__submit-btn" variant="solid" type="submit">Продовжити</Btn>
		</div>
		<p class="phone-login__notice">
			Продовжуючи, ви підтверджуєте, що згодні увійти до облікового запису FoodFactory та надаєте згоду
			на обробку персональних даних
		</p>
	</form>
	<OTP class="phone-login__step" id="otp-login-form" />
</div>
