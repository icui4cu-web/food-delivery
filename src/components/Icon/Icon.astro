---
import "./icon.scss";

interface Props {
	id: string;
	class?: string;
	fill?: string;
	spritesheet?: string;
	notSquare?: boolean;
}

const { class: className, id, spritesheet = "icons", fill, notSquare } = Astro.props;
---

<svg class:list={[className, "icon", notSquare && `icon_id_${id}`]}
	><use href={`/assets/img/${spritesheet}.svg#${id}`} {fill}></use></svg
>
