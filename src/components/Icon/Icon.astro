---
import "./icon.scss";

interface Props {
	id: string;
	class?: string;
	fill?: string;
	spritesheet?: string;
	size?: number;
}

const { class: className, id, size, spritesheet = "icons", fill } = Astro.props;
---

<svg class:list={[className, "icon"]} width={size} height={size}
	><use href={`/assets/img/${spritesheet}.svg#${id}`} {fill}></use></svg
>
