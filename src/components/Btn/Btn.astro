---
import type { HTMLTag, Polymorphic } from "astro/types";
import "./btn.scss";

import Icon from "@components/Icon/Icon.astro";

type Props<Tag extends HTMLTag> = Polymorphic<{
	as: Tag;
	variant:
		| "solid"
		| "solid-alpha"
		| "solid-beta"
		| "solid-gamma"
		| "outline"
		| "outline-muted"
		| "outline-white"
		| "solid-white"
		| "link"
		| "ghost"
		| "ghost-underline";
	size?: "lg";
	href?: string;
	class?: string;
	iconStart?: string;
	iconEnd?: string;
	type?: "button" | "submit" | "reset";
	disabled?: boolean;
	title?: string;
}>;

const {
	as: Tag = "href" in Astro.props ? "a" : "button",
	variant,
	size,
	href,
	class: className,
	iconStart,
	iconEnd,
	type = "button",
	title,
	...props
} = Astro.props;
const hasLabel = Astro.slots.has("default");
---

<Tag
	class:list={[
		className,
		"btn",
		variant && `btn_variant_${variant}`,
		size && `btn_size_${size}`,
		!hasLabel && "btn_icon-only",
	]}
	{href}
	{title}
	type={!href ? type : undefined}
	{...props}
>
	{iconStart && <Icon class="btn__icon" id={iconStart} />}
	<slot />
	{iconEnd && <Icon class="btn__icon" id={iconEnd} />}
</Tag>
