---
import Icon from "@components/Icon/Icon.astro";
import "./cart-btn.scss";

interface Props {
	label: string;
	class?: string;
}

const { class: className, label } = Astro.props;
---

<button class:list={[className, "cart-btn"]} type="button" aria-label={label}>
	<span class="cart-btn__label">{label}</span>
	<span class="cart-btn__icon">
		<Icon id="cart" />
	</span>
</button>
