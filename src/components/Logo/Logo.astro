---
import "./logo.scss";

const { class: className } = Astro.props;
const Tag = Astro.url.pathname === "/homepage" ? "h1" : "a";
const href = Tag === 'a' ? '/' : undefined
---

<Tag class:list={[className, "logo"]} {href}>
	<img class="logo__img" src="/assets/img/logo-h-dark.svg" width="311" height="70" alt="ТОВ Фуд Фекторі Київ" />
</Tag>
